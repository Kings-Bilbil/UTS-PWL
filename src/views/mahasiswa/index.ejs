<div class="bg-white p-6 rounded-2xl shadow">
  <% if (success) { %>
    <div class="bg-green-600 text-white p-4 rounded-lg mb-4 shadow"><%= success %></div>
  <% } %>
  
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-lg font-bold">Data Mahasiswa</h2>
    <a href="/mahasiswa/create" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded shadow">+ Tambah</a>
  </div>
  
  <table class="w-full text-center">
    <thead>
      <tr class="bg-gray-200 text-gray-700">
        <th class="py-3 px-4 rounded-l-lg">No</th>
        <th class="py-3 px-4">Nama</th>
        <th class="py-3 px-4">NIM</th>
        <th class="py-3 px-4 rounded-r-lg">Aksi</th>
      </tr>
    </thead>
    <tbody>
      <% mahasiswa.forEach((m, index) => { %>
        <tr class="border-b hover:bg-gray-50">
          <td class="py-3 px-4"><%= index + 1 %></td>
          <td class="py-3 px-4"><%= m.nama %></td>
          <td class="py-3 px-4"><%= m.nim %></td>
          <td class="py-3 px-4 text-sm">
            <a href="/mahasiswa/edit/<%= m.id %>" class="text-gray-500 hover:text-gray-700 mr-3">Edit</a>
            <button onclick="confirmDelete('<%= m.id %>')" class="text-red-500 hover:text-red-700">Hapus</button>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<script>
  function confirmDelete(id) {
    Swal.fire({
      icon: 'warning',
      title: 'Yakin?',
      text: 'Data akan dihapus permanen!',
      showCancelButton: true,
      confirmButtonColor: '#dc2626', 
      cancelButtonColor: '#6b7280',  
      confirmButtonText: 'Ya, hapus!',
      cancelButtonText: 'Cancel'
    }).then((result) => {
      if (result.isConfirmed) {
        window.location.href = `/mahasiswa/delete/${id}`;
      }
    })
  }
</script>