<div class="flex gap-4 mb-6">
  <div class="bg-white flex-1 p-6 rounded-2xl shadow">
    <h3 class="text-gray-500 text-sm mb-2">Total Mahasiswa</h3>
    <p class="text-3xl text-blue-600 font-bold"><%= totalMahasiswa %></p>
  </div>
  <div class="bg-white flex-1 p-6 rounded-2xl shadow">
    <h3 class="text-gray-500 text-sm mb-2">Total Dosen</h3>
    <p class="text-3xl text-green-500 font-bold">35</p>
  </div>
  <div class="bg-white flex-1 p-6 rounded-2xl shadow">
    <h3 class="text-gray-500 text-sm mb-2">Total Matkul</h3>
    <p class="text-3xl text-purple-600 font-bold">50</p>
  </div>
</div>

<div class="bg-white p-6 rounded-2xl shadow">
  <h2 class="text-lg font-bold mb-4">Data Mahasiswa Terkini</h2>
  <table class="w-full text-center">
    <thead>
      <tr class="bg-gray-200 text-gray-700">
        <th class="py-3 px-4 rounded-l-lg">No</th>
        <th class="py-3 px-4">Nama</th>
        <th class="py-3 px-4 rounded-r-lg">NIM</th>
      </tr>
    </thead>
    <tbody>
      <% if (mahasiswa.length > 0) { %>
        <% mahasiswa.forEach((m, index) => { %>
          <tr class="border-b">
            <td class="py-3 px-4"><%= index + 1 %></td>
            <td class="py-3 px-4"><%= m.nama %></td>
            <td class="py-3 px-4"><%= m.nim %></td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="3" class="py-4 text-gray-500 italic">Belum ada data mahasiswa di database.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>